# Make a copy of this to set environment variables for local development
# cp .env.example .env

# ---------------------------------------------------------------------------
# Databricks authentication
# ---------------------------------------------------------------------------
# Authenticate first: databricks auth login --profile <name>
# Then set the profile name here. Check available profiles: databricks auth profiles
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Do NOT set DATABRICKS_TOKEN when using CLI profile auth — it causes conflicts.
# Only use DATABRICKS_TOKEN if you are authenticating with a PAT instead of OAuth.
# DATABRICKS_TOKEN=dapi...

# ---------------------------------------------------------------------------
# MLflow experiment
# ---------------------------------------------------------------------------
# Set to an existing MLflow experiment ID for tracing and evaluation.
# Create one in the Databricks UI (Experiments) or via the CLI, then paste the ID here.
MLFLOW_EXPERIMENT_ID=

# ---------------------------------------------------------------------------
# MLflow tracking (usually no changes needed)
# ---------------------------------------------------------------------------
# Use the CLI profile's workspace for tracking and the Unity Catalog for registry.
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"

# ---------------------------------------------------------------------------
# Chat UI (Chainlit)
# ---------------------------------------------------------------------------
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
# Optional: custom greeting shown in the chat UI before the first message
# CHAT_GREETING=How can I help you today?

# ---------------------------------------------------------------------------
# Backend logging and message bus
# ---------------------------------------------------------------------------
# BACKEND_LOG_LEVEL=INFO

# Message bus backend options: structured_logging (default), noop, kafka, rabbitmq
# MESSAGE_BUS_BACKEND=structured_logging
# MESSAGE_BUS_TOPIC=agent-lifecycle-events
# MESSAGE_BUS_FAIL_OPEN=true

# Kafka backend settings (required when MESSAGE_BUS_BACKEND=kafka)
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_CLIENT_ID=multiagent-app

# RabbitMQ backend setting (required when MESSAGE_BUS_BACKEND=rabbitmq)
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
